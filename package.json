{
  "name": "headnumatic",
  "version": "0.4.3",
  "description": "Obsidian plugin for automatic heading numbering in technical documentation",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "headings",
    "numbering",
    "documentation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.4.0",
    "typescript": "^5.0.0"
  }
}
